<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{background:#0c0c0f;color:#ede8e0;font-family:'Nanum Myeongjo',serif;}
::-webkit-scrollbar{width:3px;}::-webkit-scrollbar-thumb{background:#2a2a30;}
a{text-decoration:none;transition:opacity .15s;}a:hover{opacity:.8;}
button{cursor:pointer;transition:all .18s;}

nav{position:sticky;top:0;z-index:100;height:62px;background:rgba(12,12,15,.97);backdrop-filter:blur(12px);border-bottom:1px solid #1a1a22;display:flex;align-items:center;justify-content:space-between;padding:0 20px;}
