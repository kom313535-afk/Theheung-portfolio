// ── GALLERY ──────────────────────────────────────
let gCur = 0, gTimer;

function galRender() {
  const sl = document.getElementById('slides');
  const dt = document.getElementById('dots');
  sl.innerHTML = '';
  dt.innerHTML = '';
  PHOTOS.forEach((src, i) => {
    const d = document.createElement('div');
    d.className = 'slide' + (i === gCur ? ' active' : '');
    d.innerHTML = '<img src="' + src + '" alt="">';
    sl.appendChild(d);
    const b = document.createElement('button');
    b.className = 'dot' + (i === gCur ? ' active' : '');
    b.onclick = () => galSet(i);
    dt.appendChild(b);
  });
}

function galSet(i) {
  clearInterval(gTimer);
  gCur = ((i % PHOTOS.length) + PHOTOS.length) % PHOTOS.length;
  galRender();
  gTimer = setInterval(() => galSet(gCur + 1), 4500);
}

function galGo(d) { galSet(gCur + d); }

galRender();
gTimer = setInterval(() => galSet(gCur + 1), 4500);

// ── PROGRAM ──────────────────────────────────────
let aCur = 0, expOpen = false;

function renderTabs() {
  const el = document.getElementById('tabs');
  el.innerHTML = '';
  const p = PROGS[aCur];
  PROGS.forEach((pg, i) => {
    const btn = document.createElement('button');
    btn.className = 'tab-btn';
    btn.textContent = pg.emoji + ' ' + pg.cat;
    btn.style.background = i === aCur ? p.accent : 'transparent';
    btn.style.color = i === aCur ? '#0c0c0f' : '#5a5858';
    btn.style.border = i === aCur ? '1px solid ' + p.accent : '1px solid #1e1e28';
    btn.style.fontWeight = i === aCur ? '700' : '400';
    btn.onclick = () => { aCur = i; expOpen = false; renderAll(); };
    el.appendChild(btn);
  });
}

function renderAll() {
  renderTabs();
  const p = PROGS[aCur];
  const card = document.getElementById('card');
  card.style.borderTop = '2px solid ' + p.accent;

  // Songs
  let h = '<div class="card-hd"><div>';
  h += '<div class="card-lbl" style="color:' + p.accent + '">Repertoire</div>';
  h += '<div class="card-title">' + p.cat + ' 추천 곡목</div>';
  h += '</div><div class="card-count">9곡</div></div>';
  p.songs.forEach((s, i) => {
    h += '<div class="song-row">';
    h += '<span class="song-num" style="color:' + p.accent + '">' + String(i+1).padStart(2,'0') + '</span>';
    h += '<span class="song-name">' + s + '</span></div>';
  });
  h += '<div class="card-note">현장 분위기·관객층에 맞춰 <strong>맞춤형 편곡·큐시트 구성</strong>이 가능합니다</div>';
  document.getElementById('card-songs').innerHTML = h;

  // Arrow
  const arrow = document.getElementById('earrow');
  arrow.style.color = p.accent;
  arrow.className = 'expand-arrow' + (expOpen ? ' open' : '');

  // Points
  let ph = '';
  p.pts.forEach((pt, i) => {
    ph += '<div class="point-row">';
    ph += '<span class="point-num" style="color:' + p.accent + '">0' + (i+1) + '</span>';
    ph += '<p class="point-txt">' + pt + '</p></div>';
  });
  const eb = document.getElementById('ebody');
  eb.innerHTML = ph;
  eb.className = 'expand-body' + (expOpen ? ' open' : '');

  // CTA
  document.getElementById('card-cta').innerHTML =
    '<a href="tel:010-7286-5868" class="cta-a" style="background:' + p.accent + '">공연 신청 · 010-7286-5868</a>';
}

function toggleExp() {
  expOpen = !expOpen;
  document.getElementById('ebody').className = 'expand-body' + (expOpen ? ' open' : '');
  document.getElementById('earrow').className = 'expand-arrow' + (expOpen ? ' open' : '');
}

