.nav-en{font-family:'Cormorant Garamond',serif;font-size:9px;color:#c9a84c;letter-spacing:.2em;text-transform:uppercase;font-style:italic;}
.nav-btn{background:#c9a84c;color:#0c0c0f;padding:8px 16px;border-radius:2px;font-family:'Hahmlet',serif;font-weight:700;font-size:13px;letter-spacing:.06em;border:none;white-space:nowrap;}

.hero{position:relative;padding:72px 20px 64px;text-align:center;border-bottom:1px solid #1a1a22;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 40% at 50% 60%,rgba(201,168,76,.07) 0%,transparent 70%);pointer-events:none;}
.hero::after{content:'';position:absolute;top:0;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(201,168,76,.35),transparent);}
.hero-inner{max-width:640px;margin:0 auto;position:relative;}
.label{font-family:'Cormorant Garamond',serif;font-size:11px;letter-spacing:.3em;color:#c9a84c;text-transform:uppercase;font-style:italic;margin-bottom:20px;}
h1{font-family:'Hahmlet',serif;font-size:clamp(26px,6vw,48px);font-weight:900;line-height:1.3;margin-bottom:20px;letter-spacing:-.01em;word-break:keep-all;}
h1 span{color:#c9a84c;}
.hero-sub{font-size:14px;color:#6a6458;line-height:1.9;margin-bottom:40px;word-break:keep-all;}
.hero-btn{display:inline-flex;align-items:center;gap:8px;background:#c9a84c;color:#0c0c0f;padding:14px 34px;font-family:'Hahmlet',serif;font-size:15px;font-weight:700;border-radius:2px;letter-spacing:.08em;border:none;}
.hero-tel{margin-top:12px;font-family:'Cormorant Garamond',serif;font-size:12px;color:#3a3836;letter-spacing:.08em;}

.about{padding:56px 20px 48px;max-width:860px;margin:0 auto;}
.gallery{position:relative;border-radius:4px;overflow:hidden;border:1px solid #1a1a22;background:#0a0a0c;aspect-ratio:16/9;}
.slide{position:absolute;inset:0;opacity:0;transition:opacity .8s ease;}
.slide.active{opacity:1;}
.slide img{width:100%;height:100%;object-fit:cover;}
.slide-fade{position:absolute;bottom:0;left:0;right:0;height:35%;background:linear-gradient(transparent,rgba(12,12,15,.6));pointer-events:none;}
.dots{position:absolute;bottom:14px;left:50%;transform:translateX(-50%);display:flex;gap:6px;z-index:2;}
.dot{height:6px;border-radius:3px;border:none;background:rgba(255,255,255,.28);padding:0;transition:all .3s ease;}
.dot.active{width:20px;background:#c9a84c;}
.dot:not(.active){width:6px;}
.arrow{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,.4);border:none;color:#fff;width:32px;height:32px;border-radius:50%;font-size:18px;display:flex;align-items:center;justify-content:center;z-index:2;line-height:1;}
.arrow.prev{left:12px;}.arrow.next{right:12px;}
.about-text{margin-top:36px;}
.about-text h2{font-family:'Hahmlet',serif;font-size:clamp(19px,3.5vw,24px);font-weight:800;margin-bottom:18px;line-height:1.5;word-break:keep-all;}
.about-text p{line-height:2.1;font-size:15px;margin-bottom:14px;word-break:keep-all;color:#9e9688;}
.about-text p:last-of-type{font-size:14px;color:#6a6458;line-height:2;margin-bottom:0;}

.divider{height:1px;background:#1a1a22;margin:0 20px;}

.prog-section{padding:56px 20px 72px;max-width:860px;margin:0 auto;}
.sec-head{text-align:center;margin-bottom:36px;}
.sec-head h2{font-family:'Hahmlet',serif;font-size:clamp(19px,3vw,25px);font-weight:800;margin-bottom:6px;}
.sec-head p{font-size:13px;color:#3e3c38;}
.tabs{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:32px;justify-content:center;}
.tab-btn{padding:7px 13px;border-radius:2px;font-size:13px;font-family:'Nanum Myeongjo',serif;font-weight:400;outline:none;}
.card{background:#101014;border:1px solid #1e1e28;border-radius:4px;overflow:hidden;}
.card-songs{padding:26px 22px 22px;}
.card-hd{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:18px;}
.card-lbl{font-family:'Cormorant Garamond',serif;font-size:10px;letter-spacing:.2em;text-transform:uppercase;font-style:italic;margin-bottom:4px;}
.card-title{font-family:'Hahmlet',serif;font-size:17px;font-weight:800;}
.card-count{font-family:'Cormorant Garamond',serif;font-size:11px;color:#3e3c38;font-style:italic;}
.song-row{display:flex;align-items:baseline;gap:14px;padding:12px 0;border-bottom:1px solid #161620;transition:all .12s;}
.song-row:last-child{border-bottom:none;}
.song-row:hover{padding-left:4px;background:rgba(255,255,255,.02);}
.song-num{font-family:'Cormorant Garamond',serif;font-size:11px;width:20px;text-align:right;flex-shrink:0;font-style:italic;}
.song-name{font-size:15px;color:#c0b8a8;line-height:1.5;}
.card-note{margin-top:18px;padding:11px 14px;background:#0c0c0f;border-radius:2px;font-size:12px;color:#4e4c48;line-height:1.8;}
.card-note strong{color:#8a8278;}
.expand-div{border-top:1px solid #1a1a22;}
.expand-btn{width:100%;padding:13px 22px;display:flex;align-items:center;justify-content:space-between;color:#4a4848;font-size:13px;font-family:'Nanum Myeongjo',serif;background:none;border:none;text-align:left;}
.expand-body{padding:4px 22px 26px;border-top:1px solid #111118;display:none;}
.expand-body.open{display:block;}
.expand-arrow{font-size:15px;transition:transform .2s;display:inline-block;}
.expand-arrow.open{transform:rotate(180deg);}
.point-row{display:flex;gap:13px;margin-top:18px;}
.point-num{font-family:'Cormorant Garamond',serif;font-size:11px;font-style:italic;flex-shrink:0;margin-top:3px;}
.point-txt{font-size:14px;color:#9a9080;line-height:1.9;word-break:keep-all;}
.card-cta{border-top:1px solid #1a1a22;padding:18px 22px;}
.cta-a{display:flex;align-items:center;justify-content:center;gap:8px;padding:13px 20px;border-radius:2px;font-family:'Hahmlet',serif;font-weight:700;font-size:15px;letter-spacing:.08em;color:#0c0c0f;}

.cta-band{background:#c9a84c;padding:60px 20px;text-align:center;}
.cta-band h2{font-family:'Hahmlet',serif;color:#0c0c0f;font-size:clamp(19px,4vw,30px);font-weight:900;margin-bottom:10px;word-break:keep-all;}
.cta-band p{color:#5a4820;margin-bottom:30px;font-size:14px;line-height:1.9;word-break:keep-all;}
.cta-main{display:inline-flex;align-items:center;gap:10px;background:#0c0c0f;color:#c9a84c;padding:15px 40px;font-family:'Hahmlet',serif;font-size:18px;font-weight:800;border-radius:2px;letter-spacing:.1em;}

footer{padding:24px 20px;border-top:1px solid #1a1a22;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
.ft-logo{display:flex;align-items:center;gap:10px;}
.ft-logo img{width:28px;height:28px;border-radius:50%;object-fit:cover;}
.ft-name{font-family:'Hahmlet',serif;font-size:13px;font-weight:700;}
.ft-copy{font-size:11px;color:#3e3c38;text-align:right;line-height:1.8;}
</style>
</head>
